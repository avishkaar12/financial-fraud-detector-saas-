DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DB_SSLMODE=require
DB_DISABLED=false

# Set true in production after frontend sends Firebase ID token.
AUTH_REQUIRED=false

# One-line JSON string from Firebase service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# CORS
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$|^https://.*\\.vercel\\.app$|^vscode-webview://.*$|^null$

# Detection performance tuning
MAX_DETECT_ROWS=50000
MAX_SHAP_EXPLANATIONS=40
